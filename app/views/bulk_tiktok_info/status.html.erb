<!DOCTYPE html>
<html>
<head>
  <title>Đang xử lý… – Bulk TikTok Info</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <style>
    body { font-family: Arial, sans-serif; background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); min-height: 100vh; margin: 0; padding: 20px; }
    .container { max-width: 620px; margin: 60px auto; }
    .card { background: white; border-radius: 15px; padding: 40px; box-shadow: 0 10px 30px rgba(0,0,0,0.3); text-align: center; }
    h1 { color: #333; font-size: 24px; margin-bottom: 6px; }
    .subtitle { color: #888; font-size: 13px; margin-bottom: 30px; }
    .job-id { font-size: 11px; color: #bbb; margin-bottom: 24px; font-family: monospace; }

    .progress-wrap { background: #f0f0f0; border-radius: 30px; height: 22px; overflow: hidden; margin: 16px 0 8px; }
    .progress-bar  { height: 100%; background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); border-radius: 30px; transition: width 0.4s ease; }
    .progress-text { font-size: 13px; color: #555; margin-bottom: 20px; }

    .status-icon { font-size: 64px; margin-bottom: 10px; animation: spin 2s linear infinite; }
    .status-icon.done   { animation: none; }
    .status-icon.failed { animation: none; }

    @keyframes spin {
      0%   { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

    .message-box { background: #f8f8f8; border-radius: 8px; padding: 12px 16px; font-size: 13px; color: #444; min-height: 44px; word-break: break-word; line-height: 1.5; margin-bottom: 20px; }

    .btn { display: inline-block; padding: 13px 28px; border-radius: 8px; font-size: 15px; font-weight: bold; cursor: pointer; text-decoration: none; border: none; }
    .btn-primary { background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); color: white; }
    .btn-secondary { background: #f0f0f0; color: #555; }

    .actions { display: flex; gap: 10px; justify-content: center; margin-top: 16px; }

    .status-badge { display: inline-block; padding: 4px 14px; border-radius: 20px; font-size: 12px; font-weight: bold; margin-bottom: 16px; }
    .badge-running { background: #fff3cd; color: #856404; }
    .badge-done    { background: #d4edda; color: #155724; }
    .badge-failed  { background: #f8d7da; color: #721c24; }
    .badge-pending { background: #cce5ff; color: #004085; }

    .link-box { background: #f0f8ff; border: 1px solid #b8daff; border-radius: 8px; padding: 10px 14px; font-size: 12px; color: #444; word-break: break-all; margin-top: 14px; }
    .link-box a { color: #0056b3; font-weight: bold; }
  </style>
</head>
<body>
  <div class="container">
    <div class="card">
      <div class="status-icon" id="status-icon">⏳</div>
      <h1>Đang xử lý Bulk TikTok Info</h1>
      <div class="subtitle">Trang sẽ tự cập nhật – bạn có thể để yên và quay lại sau</div>
      <div class="job-id">Job ID: <%= @job_id %></div>

      <span class="status-badge badge-pending" id="status-badge">Đang chờ...</span>

      <div class="progress-wrap">
        <div class="progress-bar" id="progress-bar" style="width: 0%"></div>
      </div>
      <div class="progress-text" id="progress-text">0 / ?</div>

      <div class="message-box" id="message-box">Khởi động…</div>

      <div id="action-area"></div>

      <div class="link-box">
        💡 <strong>Giữ tab này mở</strong> để tránh Railway sleep container và kill job.<br>
        Poll mỗi 3 giây sẽ giữ server thức trong suốt quá trình xử lý.<br>
        Hoặc bookmark URL này để kiểm tra sau:<br>
        <a href="<%= bulk_tiktok_info_status_url(job_id: @job_id) %>"><%= bulk_tiktok_info_status_url(job_id: @job_id) %></a>
      </div>
    </div>
  </div>

  <script>
    const jobId     = "<%= @job_id %>";
    const statusUrl = "<%= bulk_tiktok_info_status_path(job_id: @job_id, format: :json) %>";
    const resultUrl = "<%= bulk_tiktok_info_result_path(job_id: @job_id) %>";

    const icon      = document.getElementById('status-icon');
    const badge     = document.getElementById('status-badge');
    const bar       = document.getElementById('progress-bar');
    const progText  = document.getElementById('progress-text');
    const msgBox    = document.getElementById('message-box');
    const actionArea= document.getElementById('action-area');

    let pollTimer;

    function poll() {
      fetch(statusUrl, { headers: { 'Accept': 'application/json' } })
        .then(r => r.json())
        .then(data => {
          const { status, current, total, message } = data;
          const pct = total > 0 ? Math.round((current / total) * 100) : 0;

          bar.style.width = pct + '%';
          progText.textContent = current + ' / ' + total + ' URLs (' + pct + '%)';
          msgBox.textContent   = message || '';

          badge.className = 'status-badge badge-' + (status || 'pending');
          const labels = { pending: 'Đang chờ...', running: '⚙️ Đang chạy...', done: '✅ Hoàn thành', failed: '❌ Thất bại' };
          badge.textContent = labels[status] || status;

          if (status === 'running' || status === 'pending') {
            icon.textContent = '⏳';
            icon.style.animation = 'spin 2s linear infinite';
            pollTimer = setTimeout(poll, 3000);
          } else if (status === 'done') {
            icon.textContent = '🎉';
            icon.className   = 'status-icon done';
            bar.style.width  = '100%';
            actionArea.innerHTML =
              '<div class="actions">' +
              '<a href="' + resultUrl + '" class="btn btn-primary">📊 Xem Kết Quả</a>' +
              '<a href="<%= bulk_tiktok_info_path %>" class="btn btn-secondary">🔄 Chạy lại</a>' +
              '</div>';
          } else if (status === 'failed') {
            icon.textContent = '❌';
            icon.className   = 'status-icon failed';
            actionArea.innerHTML =
              '<div class="actions">' +
              '<a href="<%= bulk_tiktok_info_path %>" class="btn btn-primary">🔄 Thử lại</a>' +
              '</div>';
          } else {
            // not_found or unknown
            pollTimer = setTimeout(poll, 5000);
          }
        })
        .catch(() => {
          pollTimer = setTimeout(poll, 5000);
        });
    }

    poll();
  </script>
</body>
</html>
