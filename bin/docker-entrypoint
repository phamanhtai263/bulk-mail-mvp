#!/bin/bash -e

# Enable jemalloc for reduced memory usage and latency.
if [ -z "${LD_PRELOAD+x}" ]; then
    LD_PRELOAD=$(find /usr/lib -name libjemalloc.so.2 -print -quit)
    export LD_PRELOAD
fi

# In production, load the database schema (creates all tables from schema.rb)
if [ "${RAILS_ENV}" = "production" ]; then
  echo "==> Running db:schema:load..."
  DISABLE_DATABASE_ENVIRONMENT_CHECK=1 bundle exec rails db:schema:load
  echo "==> db:schema:load complete."
  echo "==> Running db:seed..."
  bundle exec rails db:seed
  echo "==> db:seed complete."
fi

exec "${@}"
